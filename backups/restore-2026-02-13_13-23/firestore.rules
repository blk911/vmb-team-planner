rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {


    function isTeam() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email in [
          "blk911@gmail.com",
          "TEAMMATE1@EMAIL.COM",
          "TEAMMATE2@EMAIL.COM"
        ];
    }


    match /plannerDays/{dayId} {
      allow read, write: if isTeam();
    }
    // Allow read/write so Planner and Admin can add/list members without sign-in. Use isTeam() when you enable Firebase Auth.
    match /teamMembers/{memberId} {
      allow read, write: if true;
    }
  }
}
