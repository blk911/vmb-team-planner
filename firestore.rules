// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- helpers ---
    function signedIn() {
      return request.auth != null;
    }

    function email() {
      return request.auth != null && request.auth.token.email != null
        ? request.auth.token.email
        : null;
    }

    // Team allowlist (bootstrap admins)
    function isTeam() {
      return signedIn() && (
        isMemberByUid() ||
        email() in [
        "admin@venmebaby.com"
      ]);
    }

    function isMemberByUid() {
      return signedIn() &&
        exists(/databases/$(database)/documents/teamMembers/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/teamMembers/$(request.auth.uid)).data.active == true;
    }

    function isOwnMemberDoc() {
      return signedIn() &&
        resource.data.email != null &&
        resource.data.email == email();
    }

    // Default deny (VERY IMPORTANT)
    match /{document=**} {
      allow read, write: if false;
    }

    // Collections your app uses
    match /teamMembers/{memberId} {
      allow read: if isTeam() || isOwnMemberDoc();
      allow write: if email() == "admin@venmebaby.com";
    }

    match /plannerDays/{dayId} {
      allow read, write: if isTeam();
    }

    // OPTIONAL: if you later add a "members" collection, uncomment:
    // match /members/{memberId} {
    //   allow read, write: if isTeam();
    // }
  }
}
